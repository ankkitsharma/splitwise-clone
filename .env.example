#EXPRESS
SERVER_PORT=

#ENVIRONMENT
NODE_ENV=

#JWT
SERVER_JWT=
SERVER_JWT_SECRET=
SERVER_JWT_TIMEOUT=

#DATABASE
# Use mysql when running the stack from docker-compose.yml (MySQL 8 service).
DB_DIALECT=
# Hostname of the DB: use `localhost` (or 127.0.0.1) when the API runs on your machine and MySQL is mapped from Docker; the `app` service overrides this to `db` inside Compose.
DB_HOST=
# Not `root` when using Docker Compose (official MySQL image requires a separate app user).
DB_USER=
DB_PASS=
DB_NAME=

#DOCKER — MySQL (development docker-compose)
# Root password for the MySQL container only. Choose a value and keep it out of version control in `.env`.
MYSQL_ROOT_PASSWORD=
# Host port if 3306 is already taken on your machine.
MYSQL_PORT=

#AWS
AWS_REGION=
AWS_KEYID=
AWS_SECRETKEY=
AWS_BUCKET=
